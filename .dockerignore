# .dockerignore for the unified Dockerfile (Lambda image).
# Keeps committed task.json in the image — cloud sync needs the
# hand-authored triggered_task registrations as its starting point.

.env
.env.local
.env.*.local

.git/
.gitignore
.gitattributes
.claude/
.github/

__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Generated/mutable data — produced at run time (S3-materialized on Lambda).
.tmp/
grades/
ui/
exercises/*/solution.json
exercises/*/solution.cache.json
exercises/*/expected/

# Not part of the runtime image.
backend/tests/
frontend/
infra/
docker-compose.yml
Dockerfile
.dockerignore
requirements-dev.txt
.vscode/
.idea/
*.swp
