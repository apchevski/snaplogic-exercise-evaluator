# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.

aws_region            = "eu-central-1"
name_prefix           = "snaplogic-evaluator"
data_bucket_name      = "snaplogic-evaluator-data-CHANGEME"   # must be globally unique
spa_bucket_name       = "snaplogic-evaluator-spa-CHANGEME"    # must be globally unique
cognito_domain_prefix = "snaplogic-evaluator-CHANGEME"        # must be globally unique

# Office/VPN ranges. Empty = open (NOT recommended once live).
allowed_cidrs = [
  # "203.0.113.0/24",
]

budget_alert_email = "you@example.com"
github_repo        = "your-github-user/snaplogic-exercise-evaluator"

# judge model is locked to claude-sonnet-4-6 by default; override only after
# a deliberate decision (cost changes!).
# judge_model = "claude-sonnet-4-6"
