# Environment variables
.env
.env.local
.env.*.local

# Project-specific
.tmp/*
!.tmp/.gitkeep

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# IDE
.vscode/
.idea/
*.swp

# Per-student grading reports (regenerated by /grade)
grades/

# Frontend build output (rebuilt locally by `python -m evaluator.ui` or in CI)
frontend/dist/

# Per-exercise artifacts regenerated by /prep.
# task.json IS committed: it carries the instructor's intent (output_filenames,
# triggered_task_name, requests) that prep can't re-derive, and its one
# env-specific field (solution_pipeline_path) is auto-rewritten from .env +
# description.md on the next `prep sync`. The rest below stay ignored — they're
# fetched live from SnapLogic (env-specific snode_ids + signature timestamps).
exercises/*/solution.json
exercises/*/solution.cache.json
exercises/*/expected/

# Terraform local working dirs (provider binaries); lock files ARE committed
**/.terraform/
# State files (incl. bootstrap's local state) never belong in git
*.tfstate
*.tfstate.backup
infra/environments/*/terraform.tfvars
