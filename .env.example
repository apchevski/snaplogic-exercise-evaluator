# SnapLogic API credentials (required for live API access)
SNAPLOGIC_BASE_URL=https://elastic.snaplogic.com
SNAPLOGIC_ADMIN_USERNAME=
SNAPLOGIC_ADMIN_PASSWORD=

# Solution pipeline location (the "correct answer")
SNAPLOGIC_ORG_NAME=
SNAPLOGIC_PROJECT_SPACE_NAME=
SNAPLOGIC_PROJECT_NAME=

# Default project space to search when grading a student by name.
# E.g. /grade "Gabriela Shurbeska" will look in
#   {SNAPLOGIC_ORG_NAME}/{SNAPLOGIC_STUDENT_PROJECT_SPACE}/Gabriela Shurbeska
SNAPLOGIC_STUDENT_PROJECT_SPACE=IWC_Support
