# SnapLogic API credentials (required for live API access)
SNAPLOGIC_BASE_URL=
SNAPLOGIC_ADMIN_USERNAME=
SNAPLOGIC_ADMIN_PASSWORD=

# SnapLogic organization that hosts both the solution project space
# and the student project spaces. Used as the top-level path segment
# in every pipeline lookup: {SNAPLOGIC_ORG_NAME}/<space>/<project>
SNAPLOGIC_ORG_NAME=

# Solution pipeline location (the "correct answer")
SNAPLOGIC_SOLUTION_PROJECT_SPACE=
SNAPLOGIC_SOLUTION_PROJECT=

# DEFAULT project space for students — prefills the Add Student dialog and
# fills the gap for students registered before spaces were stored per student.
# The space (and optional project name) saved on each student at registration
# is what grading actually uses. E.g. grading "Antonio Apchevski" with no
# per-student override looks in
#   {SNAPLOGIC_ORG_NAME}/{SNAPLOGIC_STUDENT_PROJECT_SPACE}/Antonio Apchevski
SNAPLOGIC_STUDENT_PROJECT_SPACE=

# Anthropic API key — required ONLY for a local full grading run
# (`python -m evaluator run <student>`), which calls Claude (Sonnet 4.6) and
# costs real money. Not needed for /prep or the single-exercise evaluator.
# In the cloud this comes from Secrets Manager, not this file.
ANTHROPIC_API_KEY=

# Optional: override the judge model (default claude-sonnet-4-6 — the locked
# project decision; changing it changes per-run cost).
# JUDGE_MODEL=claude-sonnet-4-6
